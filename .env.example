# ==============================
# Database Configuration
# ==============================

DB_NAME=cyber_db                # Database name
DB_USER=ali                     # Database username
DB_PASSWORD=change_me           # ⚠️ Replace with a strong password
DB_HOST=db                      # Database service name (Docker/K8s)
DB_PORT=5432                    # PostgreSQL port

# ==============================
# Django Configuration
# ==============================

DJANGO_SECRET_KEY=change_me     # ⚠️ Must be changed to a secure value
DJANGO_DEBUG=True               # True for development, False for production

# Allowed hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ==============================
# Redis Configuration
# ==============================

REDIS_PASSWORD=change_me        # ⚠️ Replace with a secure password
REDIS_HOST=redis               # Redis service name
REDIS_PORT=6379                # Redis port

# ==============================
# CSRF Trusted Origins
# ==============================

DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
